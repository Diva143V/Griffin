# Griffin Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to source control.

# ── Required ──────────────────────────────────────────────────
# NCBI Entrez email (required for PubMed/PMC/dbSNP collectors)
ENTREZ_EMAIL=your.email@example.com

# ── Optional API Keys ─────────────────────────────────────────
# Google Gemini API key (for peer review, QA, refinement agents)
GEMINI_API_KEY=

# Semantic Scholar API key (higher rate limits for SemanticScholar collector)
SEMANTIC_SCHOLAR_API_KEY=

# ── Run Directory ─────────────────────────────────────────────
# Override the default dataset directory.  The Reflex UI sets this
# automatically when using run-scoped workspaces.
# GRIFFIN_RUN_DIR=dataset

# ── ELN Security ──────────────────────────────────────────────
# Comma-separated list of allowed ELN hostnames beyond localhost.
# Leave empty to only allow localhost / 127.0.0.1.
# ALLOWED_ELN_DOMAINS=eln.internal.example.com

# ELN password (defaults to "admin" if unset — change in production!)
# ELN_PASSWORD=changeme

# ── Ollama / GPU ──────────────────────────────────────────────
# If Ollama fails with CUDA errors, force Vulkan compute:
# CUDA_VISIBLE_DEVICES=-1
